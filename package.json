{
  "name": "pdxhc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.functions.json && tsc --noEmit -p tsconfig.node.json",
    "og:image": "node scripts/generate-og-card.mts",
    "verify:layout": "node scripts/verify-layout.mts",
    "preview": "vite preview --host 0.0.0.0",
    "cf:preview": "npm run build && wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=pdxhc"
  },
  "dependencies": {
    "@atproto/api": "^0.20.25",
    "@atproto/oauth-client-node": "^0.4.5",
    "@lucide/vue": "latest",
    "vue": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "latest",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "latest",
    "vue-tsc": "^3.3.6",
    "wrangler": "latest"
  }
}
